# Template for local notarization credentials.
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit it.
#
# Usage:
#   cp .env.example .env.local
#   # edit .env.local with real values
#   source .env.local
#   bash scripts/sign-and-notarize.sh

# Full identity string from `security find-identity -v -p codesigning`.
# Example: "Developer ID Application: Your Name (ABCDE12345)"
export APPLE_SIGNING_IDENTITY=""

# 10-character alphanumeric team ID (also visible at developer.apple.com).
export APPLE_TEAM_ID=""

# Apple ID email tied to your Developer Program account.
export APPLE_ID=""

# App-specific password from https://account.apple.com
# (NOT your Apple ID password — generate at Sign-In and Security → App-Specific Passwords).
# Format: xxxx-xxxx-xxxx-xxxx
export APPLE_PASSWORD=""
