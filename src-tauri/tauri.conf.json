{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Remedy Canvas Desktop",
  "version": "0.1.1",
  "identifier": "com.canvasremedy.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Remedy Canvas Desktop",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:*; object-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["../sidecar/dist/bin/crd-sidecar"],
    "resources": {
      "../vendor/ollama": "vendor/ollama",
      "../vendor/liteparse": "vendor/liteparse",
      "../vendor/chromium": "vendor/chromium",
      "../vendor/axe.min.js": "vendor/axe.min.js",
      "../vendor/canvas-mock.css": "vendor/canvas-mock.css"
    },
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "wix": {
        "language": ["en-US"]
      }
    }
  }
}
